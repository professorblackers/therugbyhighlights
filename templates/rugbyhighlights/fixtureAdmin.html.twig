{% extends 'base.html.twig' %}
{% block body %}
    <section>
        <div class="container">
            <div class="fixture-card">
                <div class="league-name">
                    <p>{{ fixture[0].league }}</p>
                </div>
                <div class="team-logos">
                    <div class="team-logo">
                        <img src="{{ asset('/assets/img/' ~ fixture[0].homeTeam ~ '.png') }}" alt="{{ fixture[0].homeTeam }}">
                    </div>
                    <div class="team-logo">
                        <img src="{{ asset('/assets/img/' ~ fixture[0].awayTeam ~ '.png') }}" alt="{{ fixture[0].awayTeam }}">
                    </div>
                </div>
                <div class="kickoff-time">
                    <p>{{ fixture[0].kickOff|date("F j, Y, g:i a") }}</p>
                </div>
            </div>
            <div style="margin-left: 10px; margin-top: 10px">
                {{ form_start(form) }}
                {{ form_row(form.highlights) }}
                <div class="text-center">
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </section>
{% endblock %}